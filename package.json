{
  "name": "dental-clinic",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "python build_backend.py",
    "kill": "taskkill /F /IM \"SmileCare Clinic 1.0.0.exe\" /T || echo Process not running",
    "dist": "npm run kill && npm run build:frontend && npm run build:backend && electron-builder"
  },

  "build": {
    "appId": "com.smilecare.clinic",
    "productName": "SmileCare Clinic",
    "directories": {
      "output": "dist_electron"
    },
    "extraResources": [
      {
        "from": "backend_dist/clinic_server.exe",
        "to": "clinic_server.exe"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "frontend/public/favicon.ico"
    },
    "files": [
      "**/*",
      "!frontend/src/*",
      "!frontend/node_modules/*",
      "!backend/venv/*",
      "!backend_dist/*",
      "!build/*"
    ]
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "three": "^0.184.0"
  }
}
